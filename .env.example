# Ollama Cloud model access (never commit real values).
OLLAMA_API_KEY=

# Authenticated Cookie header copied from a request to https://ollama.com/settings.
# It must contain an Ollama session cookie such as wos-session. Keep it quoted,
# private, and refresh it here if the browser session expires.
OLLAMA_COOKIE_HEADER='wos-session=replace-me'

# Optional safety tuning. The worker pauses if either usage window reaches its
# threshold, then rechecks after Ollama's advertised reset time.
KNOWLEDGE_AI_QUOTA_SESSION_LIMIT_PERCENT=95
KNOWLEDGE_AI_QUOTA_WEEKLY_LIMIT_PERCENT=95
KNOWLEDGE_AI_QUOTA_POLL_SECONDS=60
KNOWLEDGE_AI_QUOTA_MAX_REQUESTS_BETWEEN_CHECKS=20
KNOWLEDGE_AI_QUOTA_RESET_GRACE_SECONDS=30

# Independent PDF pages can be analyzed concurrently. Start conservatively;
# Ollama Cloud may return 429 or 503 when account/model capacity is exceeded.
KNOWLEDGE_AI_PAGE_CONCURRENCY=10
KNOWLEDGE_AI_PAGE_FALLBACK_MODELS=gemma4:31b,kimi-k2.6
KNOWLEDGE_AI_PAGE_ATTEMPTS_PER_MODEL=3

# Discord is an optional eClass messages module. Existing archive channels can
# be mapped to courses by name directly from the Settings page.
DISCORD_KNOWLEDGE_ENABLED=true
DISCORD_KNOWLEDGE_WORKER_ENABLED=true
DISCORD_KNOWLEDGE_POLL_SECONDS=300
DISCORD_KNOWLEDGE_VERIFY_HASHES=true
DISCORD_POLICY_HALF_LIFE_DAYS=180
DISCORD_GENERAL_HALF_LIFE_DAYS=730

# Configure the integrated exporter from Settings → Discord Exporter.
